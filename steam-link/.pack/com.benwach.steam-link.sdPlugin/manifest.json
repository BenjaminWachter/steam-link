{
	"Name": "com.benwach.steam-link.sdPlugin",
	"Version": "0.1.4.0",
	"Author": "BenWach",
	"Actions": [
		{
			"Name": "Steam List",
			"UUID": "com.benwach.steam-link.steam-list",
			"Icon": "imgs/actions/steam-list/icon",
			"Tooltip": "Displays a list of Steam games.",
			"PropertyInspectorPath": "ui/steam-list.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/steam-list/steam-db-white",
					"TitleAlignment": "middle",
					"FontFamily": "Oswald",
					"ShowTitle": true
				}
			]
		},
		{
			"Name": "Launch Steam Game",
			"UUID": "com.benwach.steam-link.launch-steam-game",
			"Icon": "imgs/actions/launch-steam-game/icon",
			"Tooltip": "Launcher for a steam game.",
			"PropertyInspectorPath": "ui/launch-steam-game.html",
			"VisibleInActionsList": false,
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/launch-steam-game/key",
					"TitleAlignment": "middle",
					"ShowTitle": true
				}
			]
		},
		{
			"Name": "Steam Collection",
			"UUID": "com.benwach.steam-link.steam-collection",
			"Icon": "imgs/actions/steam-collection/icon",
			"PropertyInspectorPath": "ui/steam-collection.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/steam-collection/key"
				}
			]
		}
	],
	"Category": "com.benwach.steam-link.sdPlugin",
	"CategoryIcon": "imgs/plugin/category-icon",
	"CodePath": "bin/plugin.js",
	"Description": "A plugin for the Elgato Stream Deck that reads a steam profile and creates quick start buttons.",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "com.benwach.steam-link",
	"Profiles": [
		{
			"Name": "Steam Apps (auto)",
			"DeviceType": 0,
			"Readonly": false,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false
		}
	]
}